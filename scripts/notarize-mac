#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
env_file="${HERMEX_MAC_RELEASE_ENV_FILE:-"$repo_root/.env.release.local"}"

if [[ -f "$env_file" ]]; then
  set -a
  # shellcheck disable=SC1090
  source "$env_file"
  set +a
fi

if [[ $# -ne 1 ]]; then
  echo "Usage: scripts/notarize-mac /path/to/Hermex.app" >&2
  exit 2
fi

app_path="$1"
notary_profile="${NOTARYTOOL_KEYCHAIN_PROFILE:-}"

if [[ -z "$notary_profile" ]]; then
  echo "Set NOTARYTOOL_KEYCHAIN_PROFILE in .env.release.local to a profile created with 'notarytool store-credentials'." >&2
  exit 2
fi

if [[ ! -d "$app_path" ]]; then
  echo "App bundle not found: $app_path" >&2
  exit 2
fi

"$repo_root/scripts/verify-mac-app" "$app_path"

archive_path="${app_path%.*}.notarization.zip"

ditto -c -k --keepParent "$app_path" "$archive_path"
xcrun notarytool submit "$archive_path" --keychain-profile "$notary_profile" --wait
xcrun stapler staple "$app_path"
xcrun stapler validate "$app_path"
spctl --assess --type execute --verbose=4 "$app_path"
