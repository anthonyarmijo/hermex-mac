#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
env_file="${HERMEX_MAC_RELEASE_ENV_FILE:-"$repo_root/.env.release.local"}"

if [[ -f "$env_file" ]]; then
  set -a
  # shellcheck disable=SC1090
  source "$env_file"
  set +a
fi

if [[ $# -ne 1 ]]; then
  echo "Usage: scripts/notarize-mac /path/to/Hermex.app-or-dmg" >&2
  exit 2
fi

artifact_path="${1%/}"
notary_profile="${NOTARYTOOL_KEYCHAIN_PROFILE:-}"
notary_key_path="${APP_STORE_CONNECT_KEY_PATH:-}"
notary_key_id="${APP_STORE_CONNECT_KEY_ID:-}"
notary_issuer_id="${APP_STORE_CONNECT_ISSUER_ID:-}"

notary_arguments=()
if [[ -n "$notary_profile" ]]; then
  notary_arguments+=(--keychain-profile "$notary_profile")
elif [[ -n "$notary_key_path" && -n "$notary_key_id" && -n "$notary_issuer_id" ]]; then
  notary_arguments+=(--key "$notary_key_path" --key-id "$notary_key_id" --issuer "$notary_issuer_id")
else
  echo "Configure NOTARYTOOL_KEYCHAIN_PROFILE, or APP_STORE_CONNECT_KEY_PATH, APP_STORE_CONNECT_KEY_ID, and APP_STORE_CONNECT_ISSUER_ID." >&2
  exit 2
fi

case "$artifact_path" in
  *.app)
    if [[ ! -d "$artifact_path" ]]; then
      echo "App bundle not found: $artifact_path" >&2
      exit 2
    fi

    "$repo_root/scripts/verify-mac-app" "$artifact_path"

    temporary_directory="$(mktemp -d "${TMPDIR:-/tmp}/hermex-notarization.XXXXXX")"
    archive_path="$temporary_directory/Hermex.zip"
    cleanup() {
      if [[ "$temporary_directory" == "${TMPDIR:-/tmp}/hermex-notarization."* ]]; then
        rm -R "$temporary_directory"
      fi
    }
    trap cleanup EXIT

    ditto -c -k --keepParent "$artifact_path" "$archive_path"
    xcrun notarytool submit "$archive_path" "${notary_arguments[@]}" --wait
    xcrun stapler staple "$artifact_path"
    xcrun stapler validate "$artifact_path"
    spctl --assess --type execute --verbose=4 "$artifact_path"
    ;;
  *.dmg)
    if [[ ! -f "$artifact_path" ]]; then
      echo "Disk image not found: $artifact_path" >&2
      exit 2
    fi

    hdiutil verify "$artifact_path"
    codesign --verify --strict --verbose=2 "$artifact_path"
    xcrun notarytool submit "$artifact_path" "${notary_arguments[@]}" --wait
    xcrun stapler staple "$artifact_path"
    xcrun stapler validate "$artifact_path"
    spctl --assess --type open --context context:primary-signature --verbose=4 "$artifact_path"
    ;;
  *)
    echo "Unsupported artifact type: $artifact_path (expected .app or .dmg)" >&2
    exit 2
    ;;
esac
