#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
env_file="${HERMEX_MAC_RELEASE_ENV_FILE:-"$repo_root/.env.release.local"}"

if [[ -f "$env_file" ]]; then
  set -a
  # shellcheck disable=SC1090
  source "$env_file"
  set +a
fi

if [[ $# -ne 2 ]]; then
  echo "Usage: scripts/package-mac-dmg /path/to/Hermex.app /path/to/Hermex-version-macOS-universal.dmg" >&2
  exit 2
fi

app_path="${1%/}"
output_path="$2"
developer_id="${DEVELOPER_ID_APPLICATION:-Developer ID Application}"

if [[ ! -d "$app_path" ]]; then
  echo "App bundle not found: $app_path" >&2
  exit 2
fi

if [[ -e "$output_path" ]]; then
  echo "Refusing to overwrite existing disk image: $output_path" >&2
  exit 2
fi

"$repo_root/scripts/verify-mac-app" "$app_path"
xcrun stapler validate "$app_path"
spctl --assess --type execute --verbose=4 "$app_path"

temporary_directory="$(mktemp -d "${TMPDIR:-/tmp}/hermex-dmg.XXXXXX")"
staging_directory="$temporary_directory/Hermex"
temporary_dmg="$temporary_directory/Hermex.dmg"

cleanup() {
  if [[ "$temporary_directory" == "${TMPDIR:-/tmp}/hermex-dmg."* ]]; then
    rm -R "$temporary_directory"
  fi
}
trap cleanup EXIT

mkdir -p "$staging_directory" "$(dirname "$output_path")"
ditto "$app_path" "$staging_directory/Hermex.app"
ln -s /Applications "$staging_directory/Applications"

hdiutil create \
  -volname Hermex \
  -srcfolder "$staging_directory" \
  -format UDZO \
  -imagekey zlib-level=9 \
  "$temporary_dmg"

codesign --force --sign "$developer_id" --timestamp "$temporary_dmg"
codesign --verify --strict --verbose=2 "$temporary_dmg"
hdiutil verify "$temporary_dmg"
mv "$temporary_dmg" "$output_path"

echo "Packaged Mac disk image: $output_path"
